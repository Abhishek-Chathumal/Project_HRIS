# ============================================
# Project HRIS — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values

# ── General ──────────────────────────────────
NODE_ENV=development
APP_NAME=ProjectHRIS
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
API_PORT=3001

# ── Database (PostgreSQL) ────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hris_db
DATABASE_USER=hris_admin
DATABASE_PASSWORD=change_me_in_production
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Elasticsearch ────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change_me_in_production

# ── MinIO (S3-compatible storage) ────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hris-documents
MINIO_USE_SSL=false

# ── JWT Authentication ───────────────────────
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── SMTP (Email) ─────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@projecthris.com

# ── ML Service ───────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── Sentry (Error Tracking) ─────────────────
SENTRY_DSN=

# ── Logging ──────────────────────────────────
LOG_LEVEL=debug

# ── LDAP / Active Directory ──────────────────
LDAP_ENABLED=false
LDAP_URL=ldap://ldap.example.com:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=change_me
LDAP_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})
LDAP_USERNAME_ATTR=sAMAccountName
LDAP_EMAIL_ATTR=mail
LDAP_FIRSTNAME_ATTR=givenName
LDAP_LASTNAME_ATTR=sn
LDAP_GROUP_SEARCH_BASE=ou=groups,dc=example,dc=com
LDAP_GROUP_SEARCH_FILTER=(member={{dn}})
LDAP_GROUP_MEMBER_ATTR=cn
LDAP_TLS_ENABLED=false
LDAP_TLS_REJECT_UNAUTHORIZED=true
LDAP_CONNECTION_TIMEOUT=5000
LDAP_IDLE_TIMEOUT=10000
# JSON mapping: {"LDAP Group Name": "hris_role_name"}
LDAP_ROLE_MAPPING={"Domain Admins":"admin","HR":"hr_manager","Employees":"employee"}
