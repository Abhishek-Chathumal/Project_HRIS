// ============================================
// Project HRIS — Prisma Database Schema
// Industrial-Level Human Resource Information System
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── AUTHENTICATION & AUTHORIZATION ──────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  isActive      Boolean   @default(true) @map("is_active")
  isEmailVerified Boolean @default(false) @map("is_email_verified")
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  mfaSecret     String?   @map("mfa_secret") @db.VarChar(255)
  authProvider  String    @default("local") @map("auth_provider") @db.VarChar(20) // local, ldap, saml, oauth
  ldapDN        String?   @map("ldap_dn") @db.VarChar(500)
  lastLoginAt   DateTime? @map("last_login_at")
  lastLoginIp   String?   @map("last_login_ip") @db.VarChar(45)
  failedAttempts Int      @default(0) @map("failed_attempts")
  lockedUntil   DateTime? @map("locked_until")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  employee      Employee?
  userRoles     UserRole[]
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications UserNotification[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  displayName String   @map("display_name") @db.VarChar(255)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  resource    String   @db.VarChar(100)  // e.g., "employees", "leave", "payroll"
  action      String   @db.VarChar(50)   // e.g., "create", "read", "update", "delete"
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @map("refresh_token") @db.VarChar(500)
  userAgent    String?  @map("user_agent") @db.VarChar(500)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

// ── ORGANIZATION ────────────────────────────

model Organization {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  legalName    String?  @map("legal_name") @db.VarChar(255)
  taxId        String?  @map("tax_id") @db.VarChar(100)
  industry     String?  @db.VarChar(100)
  website      String?  @db.VarChar(255)
  logoUrl      String?  @map("logo_url") @db.VarChar(500)
  address      Json?    // Structured address object
  phone        String?  @db.VarChar(20)
  email        String?  @db.VarChar(255)
  timezone     String   @default("UTC") @db.VarChar(50)
  currency     String   @default("USD") @db.VarChar(3) // ISO 4217
  locale       String   @default("en") @db.VarChar(10)
  fiscalYearStart Int   @default(1) @map("fiscal_year_start") // Month (1-12)
  settings     Json?    @default("{}") // Org-wide settings
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  departments  Department[]
  locations    Location[]
  policies     Policy[]
  holidays     Holiday[]
  leaveTypes   LeaveType[]
  payrollPeriods PayrollPeriod[]

  @@map("organizations")
}

model Department {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  parentId       String?     @map("parent_id") @db.Uuid
  name           String      @db.VarChar(255)
  code           String?     @db.VarChar(50)
  description    String?     @db.Text
  headId         String?     @map("head_id") @db.Uuid
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  parent       Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children     Department[] @relation("DepartmentHierarchy")
  employees    Employee[]
  positions    Position[]

  @@index([organizationId])
  @@map("departments")
}

model Location {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(255)
  address        Json         // Structured address
  timezone       String       @db.VarChar(50)
  country        String       @db.VarChar(2) // ISO 3166-1 alpha-2
  isHeadquarters Boolean      @default(false) @map("is_headquarters")
  isActive       Boolean      @default(true) @map("is_active")
  latitude       Decimal?     @db.Decimal(10, 8)
  longitude      Decimal?     @db.Decimal(11, 8)
  geofenceRadius Int?         @map("geofence_radius") // meters
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  employees      Employee[]
  attendanceRecords AttendanceRecord[]

  @@index([organizationId])
  @@map("locations")
}

model Position {
  id           String     @id @default(uuid()) @db.Uuid
  departmentId String     @map("department_id") @db.Uuid
  title        String     @db.VarChar(255)
  code         String?    @db.VarChar(50)
  level        String?    @db.VarChar(50) // e.g., Junior, Mid, Senior, Lead
  minSalary    Decimal?   @map("min_salary") @db.Decimal(15, 2)
  maxSalary    Decimal?   @map("max_salary") @db.Decimal(15, 2)
  currency     String     @default("USD") @db.VarChar(3)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  jobPostings  JobPosting[]

  @@index([departmentId])
  @@map("positions")
}

// ── EMPLOYEE MANAGEMENT ─────────────────────

model Employee {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  employeeNumber  String   @unique @map("employee_number") @db.VarChar(50)
  departmentId    String?  @map("department_id") @db.Uuid
  positionId      String?  @map("position_id") @db.Uuid
  locationId      String?  @map("location_id") @db.Uuid
  managerId       String?  @map("manager_id") @db.Uuid

  // Personal Information
  firstName       String   @map("first_name") @db.VarChar(100)
  middleName      String?  @map("middle_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  preferredName   String?  @map("preferred_name") @db.VarChar(100)
  dateOfBirth     DateTime? @map("date_of_birth") @db.Date
  gender          String?  @db.VarChar(20)
  maritalStatus   String?  @map("marital_status") @db.VarChar(20)
  nationality     String?  @db.VarChar(2) // ISO 3166-1 alpha-2
  nationalId      String?  @map("national_id") @db.VarChar(100) // Encrypted
  photoUrl        String?  @map("photo_url") @db.VarChar(500)

  // Contact Information
  personalEmail   String?  @map("personal_email") @db.VarChar(255)
  workPhone       String?  @map("work_phone") @db.VarChar(20)
  personalPhone   String?  @map("personal_phone") @db.VarChar(20)
  currentAddress  Json?    @map("current_address")
  permanentAddress Json?   @map("permanent_address")

  // Emergency Contact
  emergencyContact Json?   @map("emergency_contact")

  // Employment Details
  employmentType  String   @default("full-time") @map("employment_type") @db.VarChar(30)
  employmentStatus String  @default("active") @map("employment_status") @db.VarChar(30)
  joiningDate     DateTime @map("joining_date") @db.Date
  confirmationDate DateTime? @map("confirmation_date") @db.Date
  probationEndDate DateTime? @map("probation_end_date") @db.Date
  terminationDate DateTime? @map("termination_date") @db.Date
  terminationReason String? @map("termination_reason") @db.Text
  noticePeriodDays Int?    @map("notice_period_days")

  // Compensation
  currentSalary   Decimal? @map("current_salary") @db.Decimal(15, 2)
  salaryCurrency  String   @default("USD") @map("salary_currency") @db.VarChar(3)
  bankDetails     Json?    @map("bank_details") // Encrypted JSON

  // Custom fields (policy-driven)
  customFields    Json?    @default("{}") @map("custom_fields")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user            User     @relation(fields: [userId], references: [id])
  department      Department? @relation(fields: [departmentId], references: [id])
  position        Position?  @relation(fields: [positionId], references: [id])
  location        Location?  @relation(fields: [locationId], references: [id])
  manager         Employee?  @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates    Employee[] @relation("ManagerSubordinates")

  documents       EmployeeDocument[]
  attendanceRecords AttendanceRecord[]
  leaveBalances   LeaveBalance[]
  leaveRequests   LeaveRequest[]
  leaveApprovals  LeaveRequest[] @relation("LeaveApprover")
  payrollRecords  PayrollRecord[]
  performanceReviews PerformanceReview[] @relation("EmployeeReviews")
  reviewsConducted   PerformanceReview[] @relation("ReviewerReviews")
  skills          EmployeeSkill[]
  trainings       TrainingEnrollment[]
  jobApplications JobApplication[]
  employmentHistory EmploymentHistory[]

  @@index([departmentId])
  @@index([positionId])
  @@index([managerId])
  @@index([employmentStatus])
  @@index([employeeNumber])
  @@map("employees")
}

model EmployeeDocument {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  title       String   @db.VarChar(255)
  category    String   @db.VarChar(100) // contract, certificate, id, etc.
  fileUrl     String   @map("file_url") @db.VarChar(500)
  fileSize    Int?     @map("file_size") // bytes
  mimeType    String?  @map("mime_type") @db.VarChar(100)
  expiryDate  DateTime? @map("expiry_date") @db.Date
  isVerified  Boolean  @default(false) @map("is_verified")
  verifiedBy  String?  @map("verified_by") @db.Uuid
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([category])
  @@map("employee_documents")
}

model EmploymentHistory {
  id                String    @id @default(uuid()) @db.Uuid
  employeeId        String    @map("employee_id") @db.Uuid
  changeType        String    @map("change_type") @db.VarChar(50) // promotion, transfer, salary_change, etc.
  previousValue     Json?     @map("previous_value")
  newValue          Json?     @map("new_value")
  effectiveDate     DateTime  @map("effective_date") @db.Date
  reason            String?   @db.Text
  approvedBy        String?   @map("approved_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")

  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([effectiveDate])
  @@map("employment_history")
}

model EmployeeSkill {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  skillName   String   @map("skill_name") @db.VarChar(255)
  proficiency String   @db.VarChar(50) // beginner, intermediate, advanced, expert
  verifiedBy  String?  @map("verified_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, skillName])
  @@map("employee_skills")
}

// ── ATTENDANCE & TIME TRACKING ──────────────

model AttendanceRecord {
  id          String    @id @default(uuid()) @db.Uuid
  employeeId  String    @map("employee_id") @db.Uuid
  locationId  String?   @map("location_id") @db.Uuid
  date        DateTime  @db.Date
  clockIn     DateTime? @map("clock_in")
  clockOut    DateTime? @map("clock_out")
  breakMinutes Int?     @map("break_minutes")
  workMinutes  Int?     @map("work_minutes") // Calculated
  overtimeMinutes Int?  @map("overtime_minutes")
  status      String    @default("present") @db.VarChar(30) // present, absent, late, half-day, holiday, leave
  source      String    @default("manual") @db.VarChar(30) // manual, biometric, geofence, web
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  geoLocation Json?     @map("geo_location") // {lat, lng}
  notes       String?   @db.Text
  isApproved  Boolean   @default(false) @map("is_approved")
  approvedBy  String?   @map("approved_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  location    Location? @relation(fields: [locationId], references: [id])

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@index([date])
  @@map("attendance_records")
}

model ShiftSchedule {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  startTime   String   @map("start_time") @db.VarChar(5) // HH:MM
  endTime     String   @map("end_time") @db.VarChar(5)
  breakMinutes Int     @default(60) @map("break_minutes")
  workDays    Int[]    @map("work_days") // [1,2,3,4,5] = Mon-Fri
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  color       String?  @db.VarChar(7) // Hex color for calendar
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("shift_schedules")
}

// ── LEAVE MANAGEMENT ────────────────────────

model LeaveType {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  name            String       @db.VarChar(255)
  code            String       @db.VarChar(20)
  description     String?      @db.Text
  defaultDays     Decimal      @map("default_days") @db.Decimal(5, 1)
  maxCarryForward Decimal?     @map("max_carry_forward") @db.Decimal(5, 1)
  maxAccumulation Decimal?     @map("max_accumulation") @db.Decimal(5, 1)
  isEncashable    Boolean      @default(false) @map("is_encashable")
  isPaid          Boolean      @default(true) @map("is_paid")
  requiresApproval Boolean     @default(true) @map("requires_approval")
  allowHalfDay    Boolean      @default(true) @map("allow_half_day")
  minDays         Decimal      @default(0.5) @map("min_days") @db.Decimal(3, 1)
  maxConsecutiveDays Int?      @map("max_consecutive_days")
  applicableGender String?     @map("applicable_gender") @db.VarChar(20)
  isActive        Boolean      @default(true) @map("is_active")
  accrualType     String       @default("annual") @map("accrual_type") @db.VarChar(20) // annual, monthly, pro-rata
  color           String?      @db.VarChar(7)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id])
  leaveBalances   LeaveBalance[]
  leaveRequests   LeaveRequest[]

  @@unique([organizationId, code])
  @@map("leave_types")
}

model LeaveBalance {
  id           String    @id @default(uuid()) @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  leaveTypeId  String    @map("leave_type_id") @db.Uuid
  year         Int
  entitled     Decimal   @db.Decimal(5, 1)
  used         Decimal   @default(0) @db.Decimal(5, 1)
  pending      Decimal   @default(0) @db.Decimal(5, 1)
  carriedOver  Decimal   @default(0) @map("carried_over") @db.Decimal(5, 1)
  adjusted     Decimal   @default(0) @db.Decimal(5, 1)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id           String    @id @default(uuid()) @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  leaveTypeId  String    @map("leave_type_id") @db.Uuid
  approverId   String?   @map("approver_id") @db.Uuid
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime  @map("end_date") @db.Date
  totalDays    Decimal   @map("total_days") @db.Decimal(5, 1)
  isHalfDay    Boolean   @default(false) @map("is_half_day")
  halfDayType  String?   @map("half_day_type") @db.VarChar(20) // first_half, second_half
  reason       String?   @db.Text
  status       String    @default("pending") @db.VarChar(20) // pending, approved, rejected, cancelled
  rejectionReason String? @map("rejection_reason") @db.Text
  actionAt     DateTime? @map("action_at")
  attachment   String?   @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id])
  approver     Employee? @relation("LeaveApprover", fields: [approverId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model Holiday {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(255)
  date           DateTime     @db.Date
  type           String       @default("public") @db.VarChar(30) // public, restricted, optional
  isRecurring    Boolean      @default(false) @map("is_recurring")
  country        String?      @db.VarChar(2)
  region         String?      @db.VarChar(100)
  createdAt      DateTime     @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, date])
  @@map("holidays")
}

// ── PAYROLL ─────────────────────────────────

model PayrollPeriod {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(255)
  startDate      DateTime     @map("start_date") @db.Date
  endDate        DateTime     @map("end_date") @db.Date
  payDate        DateTime     @map("pay_date") @db.Date
  status         String       @default("draft") @db.VarChar(20) // draft, processing, approved, paid, cancelled
  processedAt    DateTime?    @map("processed_at")
  processedBy    String?      @map("processed_by") @db.Uuid
  totalGross     Decimal?     @map("total_gross") @db.Decimal(15, 2)
  totalNet       Decimal?     @map("total_net") @db.Decimal(15, 2)
  totalDeductions Decimal?    @map("total_deductions") @db.Decimal(15, 2)
  currency       String       @default("USD") @db.VarChar(3)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  records        PayrollRecord[]

  @@index([organizationId])
  @@map("payroll_periods")
}

model PayrollRecord {
  id             String        @id @default(uuid()) @db.Uuid
  payrollPeriodId String       @map("payroll_period_id") @db.Uuid
  employeeId     String        @map("employee_id") @db.Uuid
  basicSalary    Decimal       @map("basic_salary") @db.Decimal(15, 2)
  allowances     Json?         // Structured breakdown
  deductions     Json?         // Structured breakdown
  grossSalary    Decimal       @map("gross_salary") @db.Decimal(15, 2)
  taxAmount      Decimal       @default(0) @map("tax_amount") @db.Decimal(15, 2)
  netSalary      Decimal       @map("net_salary") @db.Decimal(15, 2)
  currency       String        @default("USD") @db.VarChar(3)
  paymentMethod  String?       @map("payment_method") @db.VarChar(50)
  paymentRef     String?       @map("payment_ref") @db.VarChar(255)
  status         String        @default("draft") @db.VarChar(20) // draft, approved, paid
  payslipUrl     String?       @map("payslip_url") @db.VarChar(500)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  payrollPeriod  PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employee       Employee      @relation(fields: [employeeId], references: [id])

  @@unique([payrollPeriodId, employeeId])
  @@index([employeeId])
  @@map("payroll_records")
}

// ── RECRUITMENT ─────────────────────────────

model JobPosting {
  id           String   @id @default(uuid()) @db.Uuid
  positionId   String?  @map("position_id") @db.Uuid
  title        String   @db.VarChar(255)
  description  String   @db.Text
  requirements String?  @db.Text
  benefits     String?  @db.Text
  employmentType String @map("employment_type") @db.VarChar(30)
  experienceLevel String? @map("experience_level") @db.VarChar(50)
  salaryMin    Decimal? @map("salary_min") @db.Decimal(15, 2)
  salaryMax    Decimal? @map("salary_max") @db.Decimal(15, 2)
  currency     String?  @db.VarChar(3)
  location     String?  @db.VarChar(255)
  isRemote     Boolean  @default(false) @map("is_remote")
  status       String   @default("draft") @db.VarChar(20) // draft, open, closed, on_hold
  openings     Int      @default(1)
  publishedAt  DateTime? @map("published_at")
  closingDate  DateTime? @map("closing_date") @db.Date
  createdBy    String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  position     Position? @relation(fields: [positionId], references: [id])
  applications JobApplication[]

  @@index([status])
  @@map("job_postings")
}

model JobApplication {
  id            String    @id @default(uuid()) @db.Uuid
  jobPostingId  String    @map("job_posting_id") @db.Uuid
  employeeId    String?   @map("employee_id") @db.Uuid // For internal applicants
  firstName     String    @map("first_name") @db.VarChar(100)
  lastName      String    @map("last_name") @db.VarChar(100)
  email         String    @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  resumeUrl     String?   @map("resume_url") @db.VarChar(500)
  coverLetterUrl String?  @map("cover_letter_url") @db.VarChar(500)
  linkedinUrl   String?   @map("linkedin_url") @db.VarChar(500)
  experience    Int?      // years
  currentSalary Decimal?  @map("current_salary") @db.Decimal(15, 2)
  expectedSalary Decimal? @map("expected_salary") @db.Decimal(15, 2)
  status        String    @default("applied") @db.VarChar(30) // applied, screening, interview, offer, hired, rejected
  stage         Int       @default(1) // Pipeline stage number
  score         Decimal?  @db.Decimal(5, 2)
  mlScore       Decimal?  @map("ml_score") @db.Decimal(5, 2) // ML-based matching score
  notes         String?   @db.Text
  rejectionReason String? @map("rejection_reason") @db.Text
  source        String?   @db.VarChar(100) // referral, website, linkedin, etc.
  appliedAt     DateTime  @default(now()) @map("applied_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  jobPosting    JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  employee      Employee?  @relation(fields: [employeeId], references: [id])
  interviews    Interview[]

  @@index([jobPostingId])
  @@index([status])
  @@map("job_applications")
}

model Interview {
  id              String         @id @default(uuid()) @db.Uuid
  applicationId   String         @map("application_id") @db.Uuid
  scheduledAt     DateTime       @map("scheduled_at")
  duration        Int            @default(60) // minutes
  type            String         @db.VarChar(50) // phone, video, onsite, technical
  location        String?        @db.VarChar(255)
  meetingLink     String?        @map("meeting_link") @db.VarChar(500)
  interviewers    Json           // Array of {id, name, role}
  status          String         @default("scheduled") @db.VarChar(20) // scheduled, completed, cancelled, no_show
  feedback        Json?          // Structured feedback
  overallRating   Decimal?       @map("overall_rating") @db.Decimal(3, 1)
  notes           String?        @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  application     JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("interviews")
}

// ── PERFORMANCE MANAGEMENT ──────────────────

model PerformanceReview {
  id            String   @id @default(uuid()) @db.Uuid
  employeeId    String   @map("employee_id") @db.Uuid
  reviewerId    String   @map("reviewer_id") @db.Uuid
  cycleId       String?  @map("cycle_id") @db.Uuid
  reviewType    String   @map("review_type") @db.VarChar(50) // annual, quarterly, probation, 360
  period        String   @db.VarChar(50) // e.g., "2026-Q1", "2026"
  goals         Json?    // Array of {goal, weight, selfScore, reviewerScore, comments}
  competencies  Json?    // Array of {competency, selfScore, reviewerScore, comments}
  selfRating    Decimal? @map("self_rating") @db.Decimal(3, 1)
  reviewerRating Decimal? @map("reviewer_rating") @db.Decimal(3, 1)
  finalRating   Decimal? @map("final_rating") @db.Decimal(3, 1)
  strengths     String?  @db.Text
  improvements  String?  @db.Text
  comments      String?  @db.Text
  status        String   @default("draft") @db.VarChar(20) // draft, self_review, manager_review, calibration, completed
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  employee      Employee @relation("EmployeeReviews", fields: [employeeId], references: [id])
  reviewer      Employee @relation("ReviewerReviews", fields: [reviewerId], references: [id])

  @@index([employeeId])
  @@index([reviewerId])
  @@index([status])
  @@map("performance_reviews")
}

// ── TRAINING & LEARNING ─────────────────────

model TrainingCourse {
  id           String   @id @default(uuid()) @db.Uuid
  title        String   @db.VarChar(255)
  description  String?  @db.Text
  category     String   @db.VarChar(100)
  provider     String?  @db.VarChar(255)
  format       String   @db.VarChar(50) // online, classroom, blended, self-paced
  duration     Int?     // hours
  maxParticipants Int?  @map("max_participants")
  cost         Decimal? @db.Decimal(10, 2)
  currency     String?  @db.VarChar(3)
  isActive     Boolean  @default(true) @map("is_active")
  isMandatory  Boolean  @default(false) @map("is_mandatory")
  skills       String[] // Skills gained from this course
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  enrollments  TrainingEnrollment[]

  @@map("training_courses")
}

model TrainingEnrollment {
  id           String         @id @default(uuid()) @db.Uuid
  courseId      String         @map("course_id") @db.Uuid
  employeeId   String         @map("employee_id") @db.Uuid
  status       String         @default("enrolled") @db.VarChar(20) // enrolled, in_progress, completed, withdrawn
  progress     Int            @default(0) // percentage
  startDate    DateTime?      @map("start_date") @db.Date
  completionDate DateTime?    @map("completion_date") @db.Date
  score        Decimal?       @db.Decimal(5, 2)
  certificateUrl String?      @map("certificate_url") @db.VarChar(500)
  feedback     String?        @db.Text
  rating       Int?           // 1-5
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  course       TrainingCourse @relation(fields: [courseId], references: [id])
  employee     Employee       @relation(fields: [employeeId], references: [id])

  @@unique([courseId, employeeId])
  @@map("training_enrollments")
}

// ── POLICY ENGINE ───────────────────────────

model Policy {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  category        String       @db.VarChar(100) // attendance, leave, payroll, conduct, etc.
  name            String       @db.VarChar(255)
  slug            String       @db.VarChar(255)
  description     String?      @db.Text
  content         String       @db.Text // Rich text/markdown content
  version         Int          @default(1)
  status          String       @default("draft") @db.VarChar(20) // draft, active, archived
  effectiveDate   DateTime?    @map("effective_date") @db.Date
  expiryDate      DateTime?    @map("expiry_date") @db.Date
  rules           Json?        // Executable business rules JSON
  appliesTo       Json?        @map("applies_to") // Target criteria {departments, locations, roles, etc.}
  requiresAcknowledgment Boolean @default(false) @map("requires_acknowledgment")
  createdBy       String       @map("created_by") @db.Uuid
  approvedBy      String?      @map("approved_by") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id])
  versions        PolicyVersion[]
  acknowledgments PolicyAcknowledgment[]

  @@unique([organizationId, slug, version])
  @@index([organizationId, category])
  @@index([status])
  @@map("policies")
}

model PolicyVersion {
  id          String   @id @default(uuid()) @db.Uuid
  policyId    String   @map("policy_id") @db.Uuid
  version     Int
  content     String   @db.Text
  rules       Json?
  changeLog   String?  @map("change_log") @db.Text
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  policy      Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, version])
  @@map("policy_versions")
}

model PolicyAcknowledgment {
  id             String   @id @default(uuid()) @db.Uuid
  policyId       String   @map("policy_id") @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  acknowledgedAt DateTime @map("acknowledged_at")
  ipAddress      String?  @map("ip_address") @db.VarChar(45)

  policy         Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, employeeId])
  @@map("policy_acknowledgments")
}

// ── AUDIT LOGGING ───────────────────────────

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String   @db.VarChar(100) // CREATE, READ, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  resource    String   @db.VarChar(100) // Entity name
  resourceId  String?  @map("resource_id") @db.Uuid
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── NOTIFICATIONS ───────────────────────────

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  type        String   @db.VarChar(100) // leave_request, approval_pending, payslip_ready, etc.
  title       String   @db.VarChar(255)
  message     String   @db.Text
  data        Json?    @default("{}") // Additional context
  priority    String   @default("normal") @db.VarChar(20) // low, normal, high, urgent
  createdAt   DateTime @default(now()) @map("created_at")

  recipients  UserNotification[]

  @@map("notifications")
}

model UserNotification {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  notificationId String       @map("notification_id") @db.Uuid
  isRead         Boolean      @default(false) @map("is_read")
  readAt         DateTime?    @map("read_at")
  channel        String       @default("in_app") @db.VarChar(30) // in_app, email, sms, push
  deliveredAt    DateTime?    @map("delivered_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("user_notifications")
}

// ── SYSTEM HEALTH / DIAGNOSTICS ─────────────

model SystemHealthLog {
  id           String   @id @default(uuid()) @db.Uuid
  service      String   @db.VarChar(100)
  status       String   @db.VarChar(20) // healthy, degraded, unhealthy
  responseTime Int?     @map("response_time") // milliseconds
  details      Json?    @default("{}")
  checkedAt    DateTime @default(now()) @map("checked_at")

  @@index([service])
  @@index([checkedAt])
  @@map("system_health_logs")
}
